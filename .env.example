# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- App mode ---
# "production" (strict: requires JWT_SECRET_KEY and a non-default ADMIN_PASSWORD)
# or "dev" (relaxed: allows insecure local fallbacks).
APP_MODE=dev

# --- Security (REQUIRED in production) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
# Admin panel credentials. ADMIN_PASSWORD must NOT be empty or "admin" in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Database ---
# For cloud (Render/Neon/Supabase) set DATABASE_URL and ignore the DB_* vars below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_NAME=tommy_game_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Redis (optional; rate limiting + caching degrade gracefully if absent) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Logging ---
# Use INFO (or WARNING) in production, DEBUG in dev.
LOG_LEVEL=INFO
